<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>SMS | <%= page.replace(/_/g, ' ') %></title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <style>
        :root {
            --sidebar-bg: #1B1C31;
            --sidebar-hover: #2B2DFB;
            --bg-color: #F4F7FE;
            --text-main: #2B3674;
            --text-muted: #A3AED0;
            --card-radius: 20px;
        }
        body { font-family: 'Inter', sans-serif; background: var(--bg-color); color: var(--text-main); }

        /* Sidebar */
        .sidebar {
            position: fixed; top: 0; left: 0; bottom: 0;
            width: 280px; background: var(--sidebar-bg);
            padding: 25px 20px; overflow-y: auto; z-index: 1000;
            display: flex; flex-direction: column;
        }
        .brand-box { display: flex; align-items: center; gap: 12px; margin-bottom: 35px; padding: 0 8px; }
        .brand-logo {
            width: 42px; height: 42px; border-radius: 12px;
            background: linear-gradient(135deg, #FF9C00, #FFC048);
            display: flex; align-items: center; justify-content: center;
            color: #fff; font-weight: 700; font-size: 18px; flex-shrink: 0;
        }
        .brand-box h6 { color: #fff; margin: 0; font-weight: 700; }
        .brand-box small { color: var(--text-muted); font-size: 11px; }
        .nav-header {
            color: var(--text-muted); font-size: 11px; font-weight: 600;
            text-transform: uppercase; letter-spacing: 1px; margin: 18px 8px 8px 8px;
        }
        .nav-link-item {
            display: flex; align-items: center; gap: 12px;
            color: #9899AC; text-decoration: none; font-size: 14px; font-weight: 500;
            padding: 11px 14px; border-radius: 12px; margin-bottom: 4px; transition: all 0.2s;
        }
        .nav-link-item i { width: 18px; text-align: center; }
        .nav-link-item:hover { color: #fff; background: rgba(255,255,255,0.06); }
        .nav-link-item.active { background: var(--sidebar-hover); color: #fff; }
        .nav-link-item.logout { color: #FF4C61; }
        .trophy-card {
            background: linear-gradient(135deg, #2B2DFB, #6366F1);
            border-radius: 16px; padding: 20px; text-align: center;
            color: #fff; margin-top: auto; margin-bottom: 10px;
        }
        .trophy-card i { font-size: 28px; color: #FFC048; margin-bottom: 8px; }

        /* Main */
        .main-content { margin-left: 280px; padding: 25px 30px; }
        .top-navbar {
            display: flex; align-items: center; justify-content: space-between;
            margin-bottom: 25px; flex-wrap: wrap; gap: 15px;
        }
        .page-title { font-weight: 700; margin: 0; }
        .welcome-text { color: var(--text-muted); font-size: 13px; }
        .nav-tools { display: flex; align-items: center; gap: 12px; }
        .search-bar {
            background: #fff; border-radius: 30px; padding: 8px 18px;
            display: flex; align-items: center; gap: 8px; box-shadow: 0 4px 15px rgba(43,54,116,0.05);
        }
        .search-bar input { border: none; outline: none; font-size: 13px; width: 140px; }
        .icon-btn {
            width: 42px; height: 42px; border-radius: 50%; background: #fff; border: none;
            color: var(--text-muted); position: relative; box-shadow: 0 4px 15px rgba(43,54,116,0.05);
        }
        .icon-btn .badge {
            position: absolute; top: -2px; right: -2px; background: #FF4C61;
            font-size: 9px; padding: 3px 6px;
        }
        .profile-btn {
            background: #fff; border: none; border-radius: 30px; padding: 6px 16px 6px 6px;
            display: flex; align-items: center; gap: 10px; box-shadow: 0 4px 15px rgba(43,54,116,0.05);
        }
        .profile-btn img { width: 34px; height: 34px; border-radius: 50%; }
        .profile-btn .p-name { font-size: 13px; font-weight: 600; color: var(--text-main); text-align: left; }
        .profile-btn .p-role { font-size: 11px; color: var(--text-muted); display: block; }

        /* Cards */
        .card { border: none; border-radius: var(--card-radius); box-shadow: 0 4px 20px rgba(43,54,116,0.05); }
        .metric-card { border-radius: var(--card-radius); padding: 22px; color: #fff; height: 100%; }
        .bg-purple { background: #6366F1; }
        .bg-green { background: #00B87C; }
        .bg-orange { background: #FF9C00; }
        .bg-blue { background: #0075FF; }
        .bg-pink { background: #FF4C61; }
        .icon-badge {
            width: 44px; height: 44px; border-radius: 50%;
            background: rgba(255,255,255,0.25);
            display: flex; align-items: center; justify-content: center; margin-bottom: 12px;
        }
        .metric-card h3 { font-weight: 700; margin: 0; }
        .metric-card small { opacity: 0.85; }

        .table thead th { color: var(--text-muted); font-size: 12px; text-transform: uppercase; font-weight: 600; border: none; }
        .table td { vertical-align: middle; font-size: 14px; color: var(--text-main); }
        .avatar-sm { width: 34px; height: 34px; border-radius: 50%; }
        .status-pill { padding: 4px 12px; border-radius: 20px; font-size: 12px; font-weight: 600; }
        .pill-green { background: #E6F9F1; color: #00B87C; }
        .pill-red { background: #FFECEE; color: #FF4C61; }
        .pill-yellow { background: #FFF6E0; color: #FF9C00; }
        .form-control, .form-select { background: #F8FAFC; border-radius: 12px; border: 1px solid #E2E8F0; font-size: 14px; }
        .form-control:focus, .form-select:focus { border-color: #6366F1; box-shadow: 0 0 0 3px rgba(99,102,241,0.15); }
        .btn-indigo { background: #6366F1; color: #fff; }
        .btn-indigo:hover { background: #4F46E5; color: #fff; }
        .notif-card { display: flex; gap: 15px; align-items: flex-start; }
        .notif-icon {
            width: 44px; height: 44px; border-radius: 12px; background: #EEF0FF; color: #6366F1;
            display: flex; align-items: center; justify-content: center; flex-shrink: 0;
        }
        .result-card { border-top: 5px solid #6366F1; }
    </style>
</head>
<body>

<!-- ================= SIDEBAR ================= -->
<div class="sidebar">
    <div class="brand-box">
        <div class="brand-logo">S</div>
        <div>
            <h6>SMS</h6>
            <small>Management System</small>
        </div>
    </div>

    <a href="/app?page=dashboard" class="nav-link-item <%= page === 'dashboard' ? 'active' : '' %>">
        <i class="fa-solid fa-house"></i> Dashboard
    </a>

    <% if (user.role === 'admin') { %>
        <div class="nav-header">Academic</div>
        <a href="/app?page=courses" class="nav-link-item <%= page === 'courses' ? 'active' : '' %>"><i class="fa-solid fa-book"></i> Courses</a>
        <a href="/app?page=subjects" class="nav-link-item <%= page === 'subjects' ? 'active' : '' %>"><i class="fa-solid fa-book-open"></i> Subjects</a>
        <a href="/app?page=manage_attendance" class="nav-link-item <%= page === 'manage_attendance' ? 'active' : '' %>"><i class="fa-solid fa-clipboard-user"></i> Attendance</a>
        <a href="/app?page=manage_exams" class="nav-link-item <%= page === 'manage_exams' ? 'active' : '' %>"><i class="fa-solid fa-file-pen"></i> Exams</a>
        <div class="nav-header">Users</div>
        <a href="/app?page=manage_staff" class="nav-link-item <%= page === 'manage_staff' ? 'active' : '' %>"><i class="fa-solid fa-user-tie"></i> Staff</a>
        <a href="/app?page=manage_students" class="nav-link-item <%= page === 'manage_students' ? 'active' : '' %>"><i class="fa-solid fa-user-graduate"></i> Students</a>
        <div class="nav-header">Requests</div>
        <a href="/app?page=notifications" class="nav-link-item <%= page === 'notifications' ? 'active' : '' %>"><i class="fa-solid fa-envelope-open-text"></i> Leave Requests</a>
        <a href="/app?page=notify" class="nav-link-item <%= page === 'notify' ? 'active' : '' %>"><i class="fa-solid fa-bullhorn"></i> Send Notice</a>
    <% } else if (user.role === 'staff') { %>
        <div class="nav-header">Academic</div>
        <a href="/app?page=take_attendance" class="nav-link-item <%= page === 'take_attendance' ? 'active' : '' %>"><i class="fa-solid fa-clipboard-user"></i> Take Attendance</a>
        <a href="/app?page=view_attendance" class="nav-link-item <%= page === 'view_attendance' ? 'active' : '' %>"><i class="fa-solid fa-list-check"></i> View Attendance</a>
        <a href="/app?page=manage_exams" class="nav-link-item <%= page === 'manage_exams' ? 'active' : '' %>"><i class="fa-solid fa-file-pen"></i> Manage Exams</a>
        <div class="nav-header">Requests</div>
        <a href="/app?page=apply_leave" class="nav-link-item <%= page === 'apply_leave' ? 'active' : '' %>"><i class="fa-solid fa-calendar-minus"></i> Apply Leave</a>
        <a href="/app?page=staff_notifs" class="nav-link-item <%= page === 'staff_notifs' ? 'active' : '' %>"><i class="fa-solid fa-bell"></i> Notices</a>
    <% } else { %>
        <div class="nav-header">Academic</div>
        <a href="/app?page=my_attendance" class="nav-link-item <%= page === 'my_attendance' ? 'active' : '' %>"><i class="fa-solid fa-clipboard-user"></i> My Attendance</a>
        <a href="/app?page=exam_results" class="nav-link-item <%= page === 'exam_results' ? 'active' : '' %>"><i class="fa-solid fa-graduation-cap"></i> Exam Results</a>
        <div class="nav-header">Requests</div>
        <a href="/app?page=apply_leave" class="nav-link-item <%= page === 'apply_leave' ? 'active' : '' %>"><i class="fa-solid fa-calendar-minus"></i> Apply Leave</a>
        <a href="/app?page=student_notifs" class="nav-link-item <%= page === 'student_notifs' ? 'active' : '' %>"><i class="fa-solid fa-bell"></i> Notices</a>
        <div class="nav-header">Others</div>
        <a href="/app?page=feedback" class="nav-link-item <%= page === 'feedback' ? 'active' : '' %>"><i class="fa-solid fa-comment-dots"></i> Feedback</a>
    <% } %>

    <div class="trophy-card mt-4">
        <i class="fa-solid fa-trophy"></i>
        <div style="font-weight: 700; font-size: 14px;">Keep it up!</div>
        <small style="opacity: 0.8; font-size: 12px;">You're doing great this term.</small>
    </div>

    <a href="/logout" class="nav-link-item logout"><i class="fa-solid fa-right-from-bracket"></i> Logout</a>
</div>

<!-- ================= MAIN CONTENT ================= -->
<div class="main-content">
    <%
        const pageTitle = page.replace(/_/g, ' ').replace(/\b\w/g, c => c.toUpperCase());
        const avatarUrl = 'https://ui-avatars.com/api/?name=' + encodeURIComponent(user.full_name || 'User') + '&background=6366F1&color=fff';
    %>
    <div class="top-navbar">
        <div>
            <h4 class="page-title"><%= pageTitle %></h4>
            <span class="welcome-text">Welcome back, <%= user.full_name %>!</span>
        </div>
        <div class="nav-tools">
            <div class="search-bar"><i class="fa-solid fa-magnifying-glass text-muted"></i><input type="text" placeholder="Search..."></div>
            <button class="icon-btn"><i class="fa-regular fa-calendar"></i></button>
            <button class="icon-btn"><i class="fa-regular fa-bell"></i><span class="badge rounded-pill">3</span></button>
            <button class="profile-btn">
                <img src="<%= avatarUrl %>" alt="avatar">
                <span class="p-name"><%= user.full_name %><span class="p-role"><%= user.role %></span></span>
            </button>
        </div>
    </div>

    <% if (success_msg) { %>
        <div class="alert alert-success alert-dismissible fade show rounded-3">
            <i class="fa-solid fa-circle-check me-2"></i><%= success_msg %>
            <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
        </div>
    <% } %>

    <!-- ============ DASHBOARD ============ -->
    <% if (page === 'dashboard') { %>
        <%
            let attPct = 87;
            if (user.role === 'student' && typeof locals.total_total !== 'undefined' && locals.total_total > 0) {
                attPct = Math.round((locals.total_present / locals.total_total) * 100);
            }
        %>
        <div class="row g-3 mb-4">
            <div class="col"><div class="metric-card bg-purple"><div class="icon-badge"><i class="fa-solid fa-book"></i></div><h3><%= locals.total_courses || 0 %></h3><small>Total Courses</small></div></div>
            <div class="col"><div class="metric-card bg-green"><div class="icon-badge"><i class="fa-solid fa-book-open"></i></div><h3><%= locals.total_subjects || 0 %></h3><small>Total Subjects</small></div></div>
            <div class="col"><div class="metric-card bg-orange"><div class="icon-badge"><i class="fa-solid fa-clipboard-user"></i></div><h3><%= attPct %>%</h3><small>Attendance</small></div></div>
            <div class="col"><div class="metric-card bg-blue"><div class="icon-badge"><i class="fa-solid fa-user-graduate"></i></div><h3><%= locals.total_students || 0 %></h3><small>Total Students</small></div></div>
            <div class="col"><div class="metric-card bg-pink"><div class="icon-badge"><i class="fa-solid fa-user-tie"></i></div><h3><%= locals.total_staff || 0 %></h3><small>Total Staff</small></div></div>
        </div>

        <div class="row g-3">
            <div class="col-lg-8">
                <div class="card p-4">
                    <h6 class="fw-bold mb-3">Attendance Overview</h6>
                    <div style="position: relative; height: 300px;"><canvas id="attChart"></canvas></div>
                </div>
            </div>
            <div class="col-lg-4">
                <div class="card p-4">
                    <h6 class="fw-bold mb-3">Performance Metrics</h6>
                    <div style="position: relative; height: 300px;"><canvas id="perfChart"></canvas></div>
                </div>
            </div>
        </div>

        <script>
            const days = Array.from({length: 31}, (_, i) => (i + 1) + ' May');
            new Chart(document.getElementById('attChart'), {
                type: 'line',
                data: {
                    labels: days,
                    datasets: [
                        { label: 'Present', data: days.map(() => 60 + Math.floor(Math.random() * 35)), borderColor: '#00B87C', backgroundColor: 'rgba(0,184,124,0.1)', tension: 0.4, fill: true },
                        { label: 'Absent', data: days.map(() => Math.floor(Math.random() * 25)), borderColor: '#FF4C61', backgroundColor: 'rgba(255,76,97,0.1)', tension: 0.4, fill: true }
                    ]
                },
                options: { responsive: true, maintainAspectRatio: false }
            });
            new Chart(document.getElementById('perfChart'), {
                type: 'doughnut',
                data: {
                    labels: ['Excellent', 'Good', 'Needs Work'],
                    datasets: [{ data: [45, 35, 20], backgroundColor: ['#00B87C', '#0075FF', '#FF4C61'] }]
                },
                options: { responsive: true, maintainAspectRatio: false }
            });
        </script>

    <!-- ============ COURSES / SUBJECTS ============ -->
    <% } else if (page === 'courses' || page === 'subjects') { %>
        <div class="row g-3">
            <div class="col-lg-4">
                <div class="card p-4">
                    <h6 class="fw-bold mb-3">Add New <%= page === 'courses' ? 'Course' : 'Subject' %></h6>
                    <form method="POST" action="/app?page=<%= page %>">
                        <input type="hidden" name="action" value="<%= page === 'courses' ? 'add_course' : 'add_subject' %>">
                        <div class="mb-3">
                            <label class="form-label small fw-semibold">Name</label>
                            <input type="text" name="name" class="form-control" required>
                        </div>
                        <% if (page === 'subjects') { %>
                            <div class="mb-3">
                                <label class="form-label small fw-semibold">Course</label>
                                <select name="course_id" class="form-select" required>
                                    <option value="">Select Course</option>
                                    <% courses.forEach(c => { %><option value="<%= c._id %>"><%= c.name %></option><% }) %>
                                </select>
                            </div>
                        <% } %>
                        <button class="btn btn-indigo rounded-3 w-100"><i class="fa-solid fa-plus me-1"></i> Add</button>
                    </form>
                </div>
            </div>
            <div class="col-lg-8">
                <div class="card p-4">
                    <h6 class="fw-bold mb-3">All <%= page === 'courses' ? 'Courses' : 'Subjects' %></h6>
                    <table class="table">
                        <thead><tr><th>Name</th><% if (page === 'subjects') { %><th>Course</th><% } %><th class="text-end">Action</th></tr></thead>
                        <tbody>
                            <% const items = page === 'courses' ? courses : subjects; %>
                            <% items.forEach(item => { %>
                                <tr>
                                    <td class="fw-semibold"><%= item.name %></td>
                                    <% if (page === 'subjects') { %><td><%= item.course_id ? item.course_id.name : '-' %></td><% } %>
                                    <td class="text-end">
                                        <a href="/app?page=<%= page %>&delete=1&table=<%= page %>&id=<%= item._id %>"
                                           class="btn btn-sm btn-outline-danger rounded-3"
                                           onclick="return confirm('Delete this record?')"><i class="fa-solid fa-trash"></i></a>
                                    </td>
                                </tr>
                            <% }) %>
                            <% if (items.length === 0) { %><tr><td colspan="3" class="text-muted text-center">No records yet.</td></tr><% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

    <!-- ============ MANAGE STAFF / STUDENTS ============ -->
    <% } else if (page === 'manage_staff' || page === 'manage_students') { %>
        <% const isStudents = page === 'manage_students'; %>
        <% const users = isStudents ? (locals.students || []) : (locals.staffs || []); %>
        <div class="card p-4">
            <div class="d-flex justify-content-between align-items-center mb-3">
                <h6 class="fw-bold mb-0">All <%= isStudents ? 'Students' : 'Staff' %></h6>
                <button class="btn btn-indigo rounded-3" data-bs-toggle="modal" data-bs-target="#addUserModal">
                    <i class="fa-solid fa-plus me-1"></i> Add New
                </button>
            </div>
            <table class="table">
                <thead><tr><th>Name</th><th>Email</th><th>Gender</th><% if (isStudents) { %><th>Course</th><% } %><th class="text-end">Action</th></tr></thead>
                <tbody>
                    <% users.forEach(u => { %>
                        <tr>
                            <td>
                                <img class="avatar-sm me-2" src="https://ui-avatars.com/api/?name=<%= encodeURIComponent(u.full_name || 'U') %>&background=6366F1&color=fff">
                                <span class="fw-semibold"><%= u.full_name %></span>
                            </td>
                            <td><%= u.email %></td>
                            <td><%= u.gender || '-' %></td>
                            <% if (isStudents) { %><td><%= u.course_id ? u.course_id.name : '-' %></td><% } %>
                            <td class="text-end">
                                <a href="/app?page=<%= page %>&delete=1&table=<%= isStudents ? 'students' : 'staff' %>&id=<%= u._id %>"
                                   class="btn btn-sm btn-outline-danger rounded-3"
                                   onclick="return confirm('Delete this user?')"><i class="fa-solid fa-trash"></i></a>
                            </td>
                        </tr>
                    <% }) %>
                    <% if (users.length === 0) { %><tr><td colspan="5" class="text-muted text-center">No records yet.</td></tr><% } %>
                </tbody>
            </table>
        </div>

        <div class="modal fade" id="addUserModal" tabindex="-1">
            <div class="modal-dialog">
                <div class="modal-content" style="border-radius: 20px; border: none;">
                    <form method="POST" action="/app?page=<%= page %>">
                        <input type="hidden" name="action" value="<%= isStudents ? 'add_student' : 'add_staff' %>">
                        <div class="modal-header border-0">
                            <h6 class="fw-bold mb-0">Add New <%= isStudents ? 'Student' : 'Staff' %></h6>
                            <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                        </div>
                        <div class="modal-body">
                            <div class="mb-3"><label class="form-label small fw-semibold">Full Name</label><input type="text" name="full_name" class="form-control" required></div>
                            <div class="mb-3"><label class="form-label small fw-semibold">Email</label><input type="email" name="email" class="form-control" required></div>
                            <div class="mb-3">
                                <label class="form-label small fw-semibold">Gender</label>
                                <select name="gender" class="form-select"><option value="Male">Male</option><option value="Female">Female</option><option value="Other">Other</option></select>
                            </div>
                            <% if (isStudents) { %>
                                <div class="mb-3">
                                    <label class="form-label small fw-semibold">Course</label>
                                    <select name="course_id" class="form-select" required>
                                        <option value="">Select Course</option>
                                        <% courses.forEach(c => { %><option value="<%= c._id %>"><%= c.name %></option><% }) %>
                                    </select>
                                </div>
                            <% } %>
                            <div class="mb-2"><label class="form-label small fw-semibold">Address</label><textarea name="address" class="form-control" rows="2"></textarea></div>
                            <small class="text-muted">Default password: 123456</small>
                        </div>
                        <div class="modal-footer border-0">
                            <button type="button" class="btn btn-light rounded-3" data-bs-dismiss="modal">Cancel</button>
                            <button type="submit" class="btn btn-indigo rounded-3">Save</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

    <!-- ============ ATTENDANCE (MANAGE / TAKE) ============ -->
    <% } else if (page === 'manage_attendance' || page === 'take_attendance') { %>
        <div class="card p-4 mb-3">
            <h6 class="fw-bold mb-3">Select Class</h6>
            <form method="GET" action="/app" class="row g-2 align-items-end">
                <input type="hidden" name="page" value="<%= page %>">
                <div class="col-md-3"><label class="form-label small fw-semibold">Date</label><input type="date" name="fetch_date" class="form-control" value="<%= locals.fetch_date || '' %>" required></div>
                <div class="col-md-3">
                    <label class="form-label small fw-semibold">Course</label>
                    <select name="fetch_course" class="form-select" required>
                        <option value="">Select Course</option>
                        <% courses.forEach(c => { %><option value="<%= c._id %>" <%= locals.fetch_course == c._id.toString() ? 'selected' : '' %>><%= c.name %></option><% }) %>
                    </select>
                </div>
                <div class="col-md-3">
                    <label class="form-label small fw-semibold">Subject</label>
                    <select name="fetch_subject" class="form-select" required>
                        <option value="">Select Subject</option>
                        <% subjects.forEach(s => { %><option value="<%= s._id %>" <%= locals.fetch_subject == s._id.toString() ? 'selected' : '' %>><%= s.name %></option><% }) %>
                    </select>
                </div>
                <div class="col-md-3"><button class="btn btn-indigo rounded-3 w-100"><i class="fa-solid fa-magnifying-glass me-1"></i> Fetch Students</button></div>
            </form>
        </div>

        <% if (fetched_students.length > 0) { %>
            <div class="card p-4">
                <h6 class="fw-bold mb-3">Mark Attendance (<%= fetch_date %>)</h6>
                <form method="POST" action="/app?page=<%= page %>">
                    <input type="hidden" name="action" value="save_attendance">
                    <input type="hidden" name="date" value="<%= fetch_date %>">
                    <input type="hidden" name="course_id" value="<%= fetch_course %>">
                    <input type="hidden" name="subject_id" value="<%= fetch_subject %>">
                    <table class="table">
                        <thead><tr><th>Student</th><th>Status</th></tr></thead>
                        <tbody>
                            <% fetched_students.forEach(st => { %>
                                <% const cur = existing_attendance[st._id.toString()] || 'Present'; %>
                                <tr>
                                    <td class="fw-semibold"><%= st.full_name %></td>
                                    <td>
                                        <div class="form-check form-check-inline">
                                            <input class="form-check-input" type="radio" name="attendance[<%= st._id %>]" value="Present" <%= cur === 'Present' ? 'checked' : '' %>>
                                            <label class="form-check-label text-success fw-semibold">Present</label>
                                        </div>
                                        <div class="form-check form-check-inline">
                                            <input class="form-check-input" type="radio" name="attendance[<%= st._id %>]" value="Absent" <%= cur === 'Absent' ? 'checked' : '' %>>
                                            <label class="form-check-label text-danger fw-semibold">Absent</label>
                                        </div>
                                    </td>
                                </tr>
                            <% }) %>
                        </tbody>
                    </table>
                    <button class="btn btn-indigo rounded-3"><i class="fa-solid fa-floppy-disk me-1"></i> Save Attendance</button>
                </form>
            </div>
        <% } %>

    <!-- ============ MANAGE EXAMS ============ -->
    <% } else if (page === 'manage_exams') { %>
        <div class="card p-4 mb-3">
            <h6 class="fw-bold mb-3">Select Exam Class</h6>
            <form method="GET" action="/app" class="row g-2 align-items-end">
                <input type="hidden" name="page" value="manage_exams">
                <div class="col-md-4">
                    <label class="form-label small fw-semibold">Course</label>
                    <select name="fetch_course" class="form-select" required>
                        <option value="">Select Course</option>
                        <% courses.forEach(c => { %><option value="<%= c._id %>" <%= locals.fetch_course == c._id.toString() ? 'selected' : '' %>><%= c.name %></option><% }) %>
                    </select>
                </div>
                <div class="col-md-4">
                    <label class="form-label small fw-semibold">Subject</label>
                    <select name="fetch_subject" class="form-select" required>
                        <option value="">Select Subject</option>
                        <% subjects.forEach(s => { %><option value="<%= s._id %>" <%= locals.fetch_subject == s._id.toString() ? 'selected' : '' %>><%= s.name %></option><% }) %>
                    </select>
                </div>
                <div class="col-md-4"><button class="btn btn-indigo rounded-3 w-100"><i class="fa-solid fa-magnifying-glass me-1"></i> Fetch Students</button></div>
            </form>
        </div>

        <% if (exam_students.length > 0) { %>
            <div class="card p-4">
                <h6 class="fw-bold mb-3">Enter Scores</h6>
                <form method="POST" action="/app?page=manage_exams">
                    <input type="hidden" name="action" value="save_scores">
                    <input type="hidden" name="subject_id" value="<%= fetch_subject %>">
                    <table class="table">
                        <thead><tr><th>Student</th><th style="width: 200px;">Score (0-100)</th></tr></thead>
                        <tbody>
                            <% exam_students.forEach(st => { %>
                                <tr>
                                    <td class="fw-semibold"><%= st.full_name %></td>
                                    <td><input type="number" min="0" max="100" name="score[<%= st._id %>]" class="form-control" value="<%= existing_scores[st._id.toString()] !== undefined ? existing_scores[st._id.toString()] : '' %>"></td>
                                </tr>
                            <% }) %>
                        </tbody>
                    </table>
                    <button class="btn btn-indigo rounded-3"><i class="fa-solid fa-floppy-disk me-1"></i> Save Scores</button>
                </form>
            </div>
        <% } %>

    <!-- ============ APPLY LEAVE ============ -->
    <% } else if (page === 'apply_leave') { %>
        <div class="row g-3">
            <div class="col-lg-4">
                <div class="card p-4">
                    <h6 class="fw-bold mb-3">Request Leave</h6>
                    <form method="POST" action="/app?page=apply_leave">
                        <input type="hidden" name="action" value="apply_leave">
                        <div class="mb-3"><label class="form-label small fw-semibold">Date</label><input type="date" name="date" class="form-control" required></div>
                        <div class="mb-3"><label class="form-label small fw-semibold">Reason</label><textarea name="message" class="form-control" rows="4" required></textarea></div>
                        <button class="btn btn-indigo rounded-3 w-100"><i class="fa-solid fa-paper-plane me-1"></i> Submit Request</button>
                    </form>
                </div>
            </div>
            <div class="col-lg-8">
                <div class="card p-4">
                    <h6 class="fw-bold mb-3">My Leave History</h6>
                    <table class="table">
                        <thead><tr><th>Date</th><th>Reason</th><th>Status</th></tr></thead>
                        <tbody>
                            <% (locals.my_leaves || []).forEach(l => { %>
                                <tr>
                                    <td><%= l.date %></td>
                                    <td><%= l.message %></td>
                                    <td>
                                        <% const cls = l.status === 'Approved' ? 'pill-green' : (l.status === 'Declined' ? 'pill-red' : 'pill-yellow'); %>
                                        <span class="status-pill <%= cls %>"><%= l.status %></span>
                                    </td>
                                </tr>
                            <% }) %>
                            <% if (!locals.my_leaves || my_leaves.length === 0) { %><tr><td colspan="3" class="text-muted text-center">No leave requests yet.</td></tr><% } %>
                        </tbody>
                    </table>
                </div>
            </div>
        </div>

    <!-- ============ LEAVE REQUESTS (ADMIN) ============ -->
    <% } else if (page === 'notifications') { %>
        <div class="card p-4">
            <h6 class="fw-bold mb-3">Leave Requests</h6>
            <table class="table">
                <thead><tr><th>User</th><th>Role</th><th>Date</th><th>Message</th><th>Status</th><th class="text-end">Action</th></tr></thead>
                <tbody>
                    <% (locals.leaves || []).forEach(l => { %>
                        <tr>
                            <td class="fw-semibold"><%= l.user_id ? l.user_id.full_name : 'Unknown' %></td>
                            <td><span class="badge bg-light text-dark border rounded-pill"><%= l.role %></span></td>
                            <td><%= l.date %></td>
                            <td><%= l.message %></td>
                            <td>
                                <% const cls = l.status === 'Approved' ? 'pill-green' : (l.status === 'Declined' ? 'pill-red' : 'pill-yellow'); %>
                                <span class="status-pill <%= cls %>"><%= l.status %></span>
                            </td>
                            <td class="text-end">
                                <% if (l.status === 'Pending') { %>
                                    <form method="POST" action="/app?page=notifications" class="d-inline">
                                        <input type="hidden" name="action" value="update_leave">
                                        <input type="hidden" name="leave_id" value="<%= l._id %>">
                                        <input type="hidden" name="status" value="Approved">
                                        <button class="btn btn-sm btn-success rounded-3"><i class="fa-solid fa-check"></i></button>
                                    </form>
                                    <form method="POST" action="/app?page=notifications" class="d-inline">
                                        <input type="hidden" name="action" value="update_leave">
                                        <input type="hidden" name="leave_id" value="<%= l._id %>">
                                        <input type="hidden" name="status" value="Declined">
                                        <button class="btn btn-sm btn-danger rounded-3"><i class="fa-solid fa-xmark"></i></button>
                                    </form>
                                <% } %>
                            </td>
                        </tr>
                    <% }) %>
                    <% if (!locals.leaves || leaves.length === 0) { %><tr><td colspan="6" class="text-muted text-center">No leave requests.</td></tr><% } %>
                </tbody>
            </table>
        </div>

    <!-- ============ SEND NOTICE (ADMIN) ============ -->
    <% } else if (page === 'notify') { %>
        <div class="card p-4" style="max-width: 620px;">
            <h6 class="fw-bold mb-3">Broadcast Notification</h6>
            <form method="POST" action="/app?page=notify">
                <input type="hidden" name="action" value="send_notification">
                <div class="mb-3">
                    <label class="form-label small fw-semibold">Audience</label>
                    <select name="type" class="form-select" required>
                        <option value="student">Students</option>
                        <option value="staff">Staff</option>
                    </select>
                </div>
                <div class="mb-3"><label class="form-label small fw-semibold">Message</label><textarea name="message" class="form-control" rows="4" required></textarea></div>
                <button class="btn btn-indigo rounded-3"><i class="fa-solid fa-bullhorn me-1"></i> Send</button>
            </form>
        </div>

    <!-- ============ NOTICES (STAFF / STUDENT) ============ -->
    <% } else if (page === 'staff_notifs' || page === 'student_notifs') { %>
        <% if (locals.notifs && notifs.length > 0) { %>
            <% notifs.forEach(n => { %>
                <div class="card p-3 mb-3">
                    <div class="notif-card">
                        <div class="notif-icon"><i class="fa-solid fa-bell"></i></div>
                        <div>
                            <div class="fw-semibold"><%= n.message %></div>
                            <small class="text-muted"><i class="fa-regular fa-clock me-1"></i><%= new Date(n.created_at).toLocaleString() %></small>
                        </div>
                    </div>
                </div>
            <% }) %>
        <% } else { %>
            <div class="alert alert-info rounded-3"><i class="fa-solid fa-circle-info me-2"></i>No new notices.</div>
        <% } %>

    <!-- ============ ATTENDANCE LOGS ============ -->
    <% } else if (page === 'view_attendance' || page === 'my_attendance') { %>
        <% const rows = page === 'view_attendance' ? (locals.logs || []) : (locals.my_att || []); %>
        <div class="card p-4">
            <h6 class="fw-bold mb-3"><%= page === 'view_attendance' ? 'Recent Attendance Logs' : 'My Attendance Record' %></h6>
            <table class="table">
                <thead><tr><% if (page === 'view_attendance') { %><th>Student</th><% } %><th>Subject</th><th>Date</th><th>Status</th></tr></thead>
                <tbody>
                    <% rows.forEach(r => { %>
                        <tr>
                            <% if (page === 'view_attendance') { %><td class="fw-semibold"><%= r.student_id ? r.student_id.full_name : '-' %></td><% } %>
                            <td><%= r.subject_id ? r.subject_id.name : '-' %></td>
                            <td><%= r.date %></td>
                            <td><span class="status-pill <%= r.status === 'Present' ? 'pill-green' : 'pill-red' %>"><%= r.status %></span></td>
                        </tr>
                    <% }) %>
                    <% if (rows.length === 0) { %><tr><td colspan="4" class="text-muted text-center">No attendance records found.</td></tr><% } %>
                </tbody>
            </table>
        </div>

    <!-- ============ EXAM RESULTS (STUDENT) ============ -->
    <% } else if (page === 'exam_results') { %>
        <% if (locals.scores && scores.length > 0) { %>
            <div class="row g-3">
                <% scores.forEach(s => { %>
                    <div class="col-md-4 col-lg-3">
                        <div class="card result-card p-4 text-center">
                            <div class="text-muted small fw-semibold text-uppercase mb-2"><%= s.subject_id ? s.subject_id.name : 'Subject' %></div>
                            <h2 class="fw-bold mb-0" style="color: #6366F1;"><%= s.score %></h2>
                            <small class="text-muted">out of 100</small>
                        </div>
                    </div>
                <% }) %>
            </div>
        <% } else { %>
            <div class="alert alert-info rounded-3"><i class="fa-solid fa-circle-info me-2"></i>No exam scores available yet.</div>
        <% } %>

    <!-- ============ FEEDBACK (STUDENT) ============ -->
    <% } else if (page === 'feedback') { %>
        <div class="card p-4" style="max-width: 620px;">
            <h6 class="fw-bold mb-3">Send Feedback</h6>
            <form method="POST" action="/app?page=feedback">
                <input type="hidden" name="action" value="send_feedback">
                <div class="mb-3"><textarea name="message" class="form-control" rows="5" placeholder="Share your thoughts with the administration..." required></textarea></div>
                <button class="btn btn-indigo rounded-3"><i class="fa-solid fa-paper-plane me-1"></i> Submit Feedback</button>
            </form>
        </div>

    <% } else { %>
        <div class="alert alert-warning rounded-3">Page not found.</div>
    <% } %>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
